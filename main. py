class SplashScreen(Screen): pass
class PinCodeScreen(Screen): pass
class MainScreen(Screen): pass
class GameScreen(Screen): pass

class AnorOnlineApp(MDApp):
    def build(self):
        self.theme_cls.primary_palette = "Red"
        self.root_widget = Builder.load_string(KV)
        return self.root_widget

    def on_start(self):
        # Аксҳоро маҳз ҳангоми ба кор даромадан танзим мекунем
        self.set_images()

    def set_images(self):
        try:
            # Танзими суроғаҳо барои аксҳои ту
            self.root.ids.bg_img.source = get_path('background.jpg')
            self.root.ids.menu_logo.source = get_path('logo.jpg')
            # Кӯшиш мекунем ба SplashScreen дастрасӣ пайдо кунем
            splash = self.root.ids.screen_manager.get_screen('splash')
            splash.ids.splash_logo.source = get_path('logo.jpg')
        except Exception as e:
            print(f"Акс бор нашуд: {e}")

    def go_back(self):
        self.root.ids.screen_manager.current = "main"

if __name__ == '__main__':
    AnorOnlineApp().run()
